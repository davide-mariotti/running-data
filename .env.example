# Credenziali Garmin Connect (le stesse dell'app/sito)
GARMIN_EMAIL=la_tua_email_garmin@example.com
GARMIN_PASSWORD=la_tua_password_garmin

# API Key Gemini (da aistudio.google.com/apikey)
GEMINI_API_KEY=la_tua_chiave_api_gemini_qui

# Firebase Project ID
FIREBASE_PROJECT_ID=il_tuo_project_id_firebase

# User ID per Firestore (il tuo Firebase Auth UID, impostato dopo il primo login)
ATHLETE_USER_ID=athlete_main
