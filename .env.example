# Inserisci qui la tua chiave API di Gemini (ottenibile gratuitamente su https://aistudio.google.com/)
GEMINI_API_KEY=tuo_api_key_qui

# Opzionale: imposta anno e settimana (es. W40) per testare l'analisi di una singola settimana specifica.
# Se lasciati vuoti, lo script elaborerà tutte le settimane in ordine cronologico.
TARGET_YEAR=
TARGET_WEEK=

# Opzionale: se il modello predefinito (gemini-2.5-flash) è sovraccarico (errore 503),
# puoi forzare l'uso di un altro modello (es: gemini-1.5-flash o gemini-1.5-pro)
GEMINI_MODEL=
