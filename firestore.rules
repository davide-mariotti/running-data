rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Credenziali utenti: ogni utente può leggere e scrivere solo le proprie
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Dati atleta: permettiamo a chiunque sia loggato di leggere (così admin legge athlete_main)
    match /athletes/{userId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Solo backend Python (Admin SDK bypassa le rules)
    }

    // Configurazione sistema (token Garmin etc): solo backend
    match /system/{document=**} {
      allow read, write: if false;
    }
  }
}
